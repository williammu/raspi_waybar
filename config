{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    
    "modules-left": [],
    "modules-center": ["custom/cpug", "custom/cores", "custom/topcpu", "custom/gpu", "custom/wifi", "custom/load", "custom/mem_combined", "custom/disk"],
    "modules-right": [],
    
    "custom/cpug": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/cpu_graph.sh",
        "interval": 1,
        "tooltip": true,
        "tooltip-format": "CPU 总使用率\n图表: 最近4次采样历史"
    },
    
    "custom/cores": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/cores_graph.sh",
        "interval": 1,
        "tooltip": true,
        "tooltip-format": "4核心 CPU 使用率\n每个核心显示最近4次采样历史"
    },
    
    "custom/topcpu": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/topcpu.sh",
        "interval": 2,
        "tooltip": true,
        "tooltip-format": "CPU 温度与 TOP3 进程\n显示当前CPU温度及占用最高的3个进程"
    },
    
    "custom/gpu": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/gpu.sh",
        "interval": 2,
        "tooltip": true,
        "tooltip-format": "GPU 使用率\n基于 v3d gpu_stats 计算\n图表: 最近4次采样历史"
    },
    
    "custom/wifi": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/wifi_info.sh",
        "interval": 1,
        "tooltip": true,
        "tooltip-format": "WiFi 网络状态\n信号强度百分比\n↓下载速度 ↑上传速度 (KB/s)"
    },
    
    "custom/mem_combined": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/mem_combined.sh",
        "interval": 2,
        "tooltip": true,
        "tooltip-format": "内存使用情况\n已用/总共 内存容量\n占用百分比\nTOP3 内存消耗进程"
    },
    
    "custom/disk": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/disk.sh",
        "interval": 10,
        "tooltip": true,
        "tooltip-format": "根分区 (/) 磁盘使用情况\n使用率百分比\n总容量大小"
    },
    
    "custom/load": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/load.sh",
        "interval": 5,
        "tooltip": true,
        "tooltip-format": "系统平均负载 (1分钟)\n表示最近1分钟内运行队列中的平均进程数\n4核系统满载=4.0"
    }
}
